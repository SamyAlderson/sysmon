// Main command-line interface definition
use clap::{App, Arg, SubCommand};
use serde_json::json;
use log::{debug, error};

fn main() {
    // Initialize Clap CLI
    let matches = App::new("sysmon")
        .version("1.0")
        .author("Samy Alderson")
        .about("System monitor CLI tool")
        .arg(Arg::with_name("config")
             .short("c")
             .long("config")
             .value_name("FILE")
             .help("Path to configuration file"))
        .subcommand(SubCommand::with_name("monitor")
                    .about("Start system monitoring"))
        .subcommand(SubCommand::with_name("alert")
                    .about("Configure alerting"))
        .get_matches();

    // Handle configuration file path
    let config_path = matches.value_of("config");
    let config = match config_path {
        Some(path) => {
            // Load configuration from file
            debug!("Loading configuration from file: {}", path);
            // For simplicity, just load from file directly
            let config_str = std::fs::read_to_string(path).unwrap();
            serde_json::from_str(&config_str).unwrap()
        }
        None => {
            // Default configuration
            debug!("Using default configuration");
            json!({
                "monitoring": true,
                "alerting": true,
                "metric_collection": true
            })
        }
    };

    // Handle subcommands
    match matches.subcommand() {
        ("monitor", Some(_)) => {
            // Start system monitoring
            debug!("Starting system monitoring");
            // This was tricky, but it works
            // TODO: this will be replaced with real monitoring code
            println!("Monitoring started");
        }
        ("alert", Some(_)) => {
            // Configure alerting
            debug!("Configuring alerting");
            // Not proud of this but it works
            // TODO: this will be replaced with real alerting code
            println!("Alerting configured");
        }
        _ => {
            // Show help message
            debug!("Showing help message");
            // This was tricky to get right, but it's working
            matches.print_help();
        }
    }
}